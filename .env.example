# SQLite — local file db
DATABASE_URL="file:./dev.db"

# Optional: TCGdex prefers no key. Override base if you self-host.
TCGDEX_BASE_URL="https://api.tcgdex.net/v2"

# Optional default language for TCGdex card data ("en", "de", "fr", ...)
TCGDEX_LANG="de"

# Languages searched by name AND tried when resolving a card id (comma-separated).
# Card names/sets are localized: searching only "de" misses English queries like
# "Charizard" (German "Glurak"), and Japanese-only cards like "sv3 113" live solely
# under /ja/. Defaults to "<TCGDEX_LANG>,en,ja". Add more for wider coverage.
TCGDEX_SEARCH_LANGS="de,en,ja"

# Default currency for display
DEFAULT_CURRENCY="EUR"
